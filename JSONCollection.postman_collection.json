                  "pm.collectionVariables.set(\"actualJob\", jsonData.job);\r",
                  "console.log(\"POST Expected:\", pm.iterationData.get(\"randomJobTitle\"));\r",
                  "console.log(\"POST Actual:\", jsonData.job);\r",
                  "\r",
                  "// store expected job from CSV into collection variable\r",
