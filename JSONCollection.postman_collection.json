                  "console.log(\"POST Expected:\", pm.iterationData.get(\"value\"));\r",
                  "console.log(\"POST Actual:\", jsonData.job);\r",
                  "\r",
                  "pm.test(\"JSON Post\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.environment.set(\"userId\", jsonData.id);\r",
                  "});\r",
                  "pm.execution.setNextRequest(\"JSON Get\")"
